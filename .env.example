# =============================================
# MobiTrak Backend — Environment Variables
# =============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. See .gitignore.
# For production: set these as Lambda environment variables or GitHub Secrets.

# --- Node Environment ---
NODE_ENV=development

# --- MongoDB Configuration ---
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname

# --- JWT Configuration ---
JWT_SECRET=your_jwt_secret_key_here_min_32_chars

# --- Frontend URL (for CORS and Google OAuth redirect) ---
FRONTEND_URL=http://localhost:5173

# --- Google OAuth ---
GOOGLE_CLIENT_ID=your_google_client_id_here

# --- SMTP Email Configuration ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
EMAIL_FROM=MobiTrak <your_email@gmail.com>

# --- Cloudinary Configuration ---
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# --- OCR.space API Keys ---
OCR_SPACE_API_KEY_USER=your_ocr_api_key_for_user_service
OCR_SPACE_API_KEY_VEHICLE=your_ocr_api_key_for_vehicle_service

# --- OpenRouter AI Configuration ---
OPENROUTER_API_KEY_USER=your_openrouter_key_for_user_service
OPENROUTER_API_KEY_VEHICLE=your_openrouter_key_for_vehicle_service
AI_API_URL=https://openrouter.ai/api/v1/chat/completions
AI_MODEL=openai/gpt-4o-mini

# --- Mapbox Configuration ---
MAPBOX_ACCESS_TOKEN=your_mapbox_access_token_here

# --- Razorpay (reserved for future implementation) ---
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here

# --- Service Ports (local Docker dev only) ---
USER_SERVICE_PORT=5001
VEHICLE_SERVICE_PORT=5002
DRIVER_SERVICE_PORT=5003
TRIP_SERVICE_PORT=5004

# --- Inter-service URLs (Docker Compose internal) ---
USER_SERVICE_URL=http://user-service:5001
NOTIFICATION_SERVICE_URL=http://user-service:5001
